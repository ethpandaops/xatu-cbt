<?xml version="1.0"?>
<clickhouse replace="true">
    <profiles>
        <default>
            <max_memory_usage>20000000000</max_memory_usage>
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <load_balancing>in_order</load_balancing>
            <log_queries>1</log_queries>
            <!-- prod clickhouse-raw parity: keep pooled inter-node connections alive -->
            <tcp_keep_alive_timeout>60</tcp_keep_alive_timeout>
            <!-- prod parity: stream cross-shard aggregation instead of buffering -->
            <distributed_aggregation_memory_efficient>1</distributed_aggregation_memory_efficient>
            <!-- prod parity: raw ingest batches span wide date ranges; default of 100 partitions
                 per insert block jams Distributed sends. prod raises this to 1000. -->
            <max_partitions_per_insert_block>1000</max_partitions_per_insert_block>
            <!-- The harness clones ~113 external databases up front. With distributed_ddl
                 pool_size raised the ON CLUSTER backlog drains fast, but give the issuing
                 client a generous ceiling (default is 180s) so a momentarily deep queue
                 never trips code 159 TIMEOUT_EXCEEDED. -->
            <distributed_ddl_task_timeout>600</distributed_ddl_task_timeout>
        </default>
        <readonly>
            <max_memory_usage>20000000000</max_memory_usage>
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <load_balancing>in_order</load_balancing>
            <readonly>2</readonly>
            <log_queries>1</log_queries>
            <!-- prod parity (user profile): reject queries that can't use the primary key index -->
            <force_primary_key>1</force_primary_key>
            <constraints>
                <max_execution_time>
                <changeable_in_readonly/>
                <min>0</min>
                <max>180</max>
                </max_execution_time>
            </constraints>
        </readonly>
    </profiles>
    <users>
        <default>
            <access_management>1</access_management>
            <profile>default</profile>
            <networks>
                <ip>::/0</ip>
            </networks>
            <quota>default</quota>
            <access_management>1</access_management>
            <password from_env="CLICKHOUSE_PASSWORD" replace="replace"></password>
            <named_collection_control>1</named_collection_control>
            <show_named_collections>1</show_named_collections>
            <show_named_collections_secrets>1</show_named_collections_secrets>
        </default>
        <readonly>
            <access_management>0</access_management>
            <profile>readonly</profile>
            <networks>
                <ip>::/0</ip>
            </networks>
            <password from_env="CLICKHOUSE_USER_READONLY_PASSWORD" replace="replace"></password>
            <quota>default</quota>
        </readonly>
    </users>
    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>
</clickhouse>
